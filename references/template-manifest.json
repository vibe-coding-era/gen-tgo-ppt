    ],
    "allow_mixed_page_styles": true,
    "preserve_tgo_gtlc_background": true
  },
  "style_thumbnails": {
    "9": "assets/design/previews/styles/style-09-enterprise-ai-consulting.png"
  },
  "template_previews": {
    "contact_sheet": "assets/design/previews/templates/template-contact-sheet.png",
    "tgo-daily": "assets/design/previews/templates/tgo-daily-template-contact-sheet.png",
    "loop-orange-white-selector": "assets/design/branches/loop-orange-white/tgo-gtlc-style-branches-contact-sheet.png",
    "loop-orange-white-complete": "assets/design/branches/loop-orange-white/loop-2026-template-complete-contact-sheet.png"
  },
  "template_defaults": {
    "GTLC 大会": "light",
    "TGO日常活动分享": "tgo-daily"
  },
  "branch_styles": {
    "D": {
      "id": "GTLC-LOOP-OrangeWhite",
      "name": "LOOP Summit 橙白峰会风",
      "template_key": "loop-orange-white",
      "role": "GTLC branch style for AI ecosystem summits, sponsor benefits, city chapter events, and event-facing decks",
      "selector_pdf": "assets/design/branches/loop-orange-white/tgo-gtlc-style-branches.pdf",
      "complete_preview_pdf": "assets/design/branches/loop-orange-white/loop-2026-template-complete.pdf",
      "default_for_gtlc": false
    }
  },
  "layout_safety": {
    "version": "V8.02",
    "policy": "references/rule-layout-safety-v802.md",
    "rule_files": [
      "references/workflow.md",
      "references/rule-intake.md",
      "references/rule-ppt-structure.md",
      "references/rule-template-selection.md",
      "references/rule-page-styles.md",
      "references/rule-validation.md",
      "references/rule-subagents.md",
      "references/rule-ssot-handoff.md",
      "references/rule-guardrails.md",
      "references/generation-log.md",
      "references/conversion-workflows.md"
    ],
    "checker_script": "scripts/check_pptx_layout.py",
    "key_page_solid_panel_required": true,
    "key_page_panel_color": "#061C4C",
    "native_cover_exception_requires_user_confirmation": true,
    "agenda_page_index": 3,
    "agenda_page_order_required_when_present": true,
    "agenda_page_no_narrative_header": true,
    "default_margin_in": 0.45,
    "footer_keepout_in": 0.75,
    "logo_keepout_in": {
      "width": 3.2,
      "height": 1.0
    },
    "font_minimums_pt": {
      "body": 20,
      "supporting": 16,
      "table_caption": 14,
      "hard_min": 12
    },
    "content_budget": {
      "common_bullets": 5,
      "bullet_cjk_chars": 28,
      "two_column_bullets_per_column": 4,
      "table_rows": 6,
      "table_cols": 5
    },
    "overflow_order": [
      "shorten_or_merge_text",
      "enlarge_box_inside_safe_area",
      "reduce_font_within_limits",
      "switch_layout",
      "split_slide",
      "ask_user_when_source_fidelity_conflicts_with_readability"
    ]
  },
  "subagents": {
    "generation": {
      "name": "生成内容",
      "scope": "outline, one-page sample, or full deck generation",
      "may_validate_own_output": false
    },
    "style_review": {
      "name": "检查风格",
      "scope": "visual fidelity only",
      "must_differ_from_generation_subagent": true
    },
    "text_review": {
      "name": "检查文字",
      "scope": "Chinese wording, content quality, and source fidelity only",
      "must_differ_from_generation_subagent": true
    }
  },
  "subagent_policy": {
    "generation_and_validation_must_be_different": true,
    "generation_subagent": "生成内容",
    "validation_subagents": ["检查风格", "检查文字"],
    "forbidden": [
      "same_subagent_generates_and_validates_same_output",
      "generation_subagent_approves_own_deck",
      "validation_subagent_validates_content_it_generated"
    ],
    "fallback_when_subagents_unavailable": "record limitation in generation log and run separated lead self-review passes without claiming independent subagent validation"
  },
  "generation_log": {
    "required": true,
    "location": "current_working_directory",
    "filename_pattern": "gen-tgo-ppt-生成日志-YYYYMMDD-HHMMSS.md",
    "create_before": "one_page_sample_or_full_output",
    "update_before_final_delivery": true,
    "helper_script": "scripts/create_generation_log.py",
    "required_sections": [
      "task_metadata",
      "user_choices",
      "content_discussion",
      "deck_plan",
      "layout_safety_budget",
      "subagent_assignment",
      "sample_output",
      "final_outputs",
      "pptx_layout_check",
      "style_review",
      "text_review",
      "deferred_issues"
    ]
  },
  "workflow_gates": [
    {
      "id": "progressive_design_loading_after_clarification",
      "actor": "lead",
      "requires_user_confirmation": false
    },
    {
      "id": "content_discussion_after_source_read",
      "actor": "lead",
      "requires_user_confirmation": true
    },
    {
      "id": "deck_plan_with_page_count_and_per_slide_outline",
      "actor": "lead",
      "requires_user_confirmation": true
    },
    {
      "id": "generation_log_in_current_directory",
      "actor": "lead",
      "requires_user_confirmation": false,
      "required_before": "one_page_sample_or_full_output"
    },
    {
      "id": "one_page_sample_confirmation",
      "actor": "lead",
      "requires_user_confirmation": true
    },
    {
      "id": "generation_subagent_assignment",
      "actor": "separate_subagent",
      "subagent_name": "生成内容",
      "requires_user_confirmation": false,
      "scope": "sample_and_full_output_generation"
    },
    {
      "id": "subagent_separation",
      "actor": "lead",
      "requires_user_confirmation": false,
      "required_before": "independent_style_review",
      "rule": "generation_subagent_must_differ_from_validation_subagents"
    },
    {
      "id": "pptx_layout_check_and_fail_fix",
      "actor": "lead",
      "requires_user_confirmation": false,
      "required_before": "independent_style_review"
    },
    {
      "id": "independent_style_review",
      "actor": "separate_subagent",
      "subagent_name": "检查风格",
      "order": 1,
      "before": "independent_content_review",
      "scope": "visual_fidelity_only"
    },
    {
      "id": "independent_content_review",
      "actor": "separate_subagent",
      "subagent_name": "检查文字",
      "order": 2,
      "after": "independent_style_review",
      "scope": "chinese_wording_content_quality_and_source_fidelity_only"
    }
  ],
  "canvas": {
    "width_in": 26.667,
    "height_in": 15.0,
